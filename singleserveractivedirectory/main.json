{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "10241162623851324796"
    }
  },
  "parameters": {
    "abbreviation": {
      "type": "string",
      "defaultValue": "jv",
      "minLength": 2,
      "maxLength": 6,
      "metadata": {
        "description": "Abbreviation used in Azure resource names. Default is jv."
      }
    },
    "adminUsername": {
      "type": "string",
      "metadata": {
        "description": "Username for the Windows Server VM."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Password. Required. Local administrator password for the Windows Server VM. Use a strong password."
      }
    },
    "dsrmPassword": {
      "type": "securestring",
      "metadata": {
        "description": "DSRM password. Required. Separate Directory Services Restore Mode password for Active Directory recovery."
      }
    },
    "sourceIpAddress": {
      "type": "string",
      "metadata": {
        "description": "Public IPv4 address that is allowed to connect with RDP. Enter only the IP address, without prefixes (like /32)."
      }
    },
    "vmSize": {
      "type": "string",
      "metadata": {
        "description": "Enter an Azure VM size, for example Standard_D2as_v5 or Standard_D2as_v7."
      },
      "defaultValue": "Standard_E2as_v7"
    },
    "domainName": {
      "type": "string",
      "metadata": {
        "description": "Active Directory domain name."
      },
      "defaultValue": "internal.justinverstijnen.nl"
    },
    "domainNetbiosName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 15,
      "metadata": {
        "description": "NETBIOS name. Active Directory NetBIOS name. Use 1 to 15 characters."
      },
      "defaultValue": "JV"
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Add Azure resource tags as a JSON object. Leave blank if no tags are needed."
      }
    }
  },
  "variables": {
    "abbreviationLower": "[toLower(parameters('abbreviation'))]",
    "vnetName": "[format('vnet-{0}-vnet01', variables('abbreviationLower'))]",
    "subnetName": "[format('snet-{0}-snet01', variables('abbreviationLower'))]",
    "nsgName": "[format('nsg-{0}-nsg01', variables('abbreviationLower'))]",
    "publicIpName": "[format('pip-{0}-dc01', variables('abbreviationLower'))]",
    "nicName": "[format('nic-{0}-dc01', variables('abbreviationLower'))]",
    "vmName": "[format('vm-{0}-dc01', variables('abbreviationLower'))]",
    "osDiskName": "[format('osdisk-{0}-dc01', variables('abbreviationLower'))]",
    "rdpRuleName": "Allow-RDP-Inbound",
    "encodedDsrmPassword": "[base64(parameters('dsrmPassword'))]",
    "installAdScriptLines": [
      "$ErrorActionPreference = 'Stop'",
      "Install-WindowsFeature AD-Domain-Services -IncludeManagementTools",
      "[format('$dsrmPasswordPlain = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String(''{0}''))', variables('encodedDsrmPassword'))]",
      "$secureDsrmPassword = ConvertTo-SecureString $dsrmPasswordPlain -AsPlainText -Force",
      "[format('Install-ADDSForest -DomainName ''{0}'' -DomainNetbiosName ''{1}'' -SafeModeAdministratorPassword $secureDsrmPassword -InstallDNS -Force -NoRebootOnCompletion:$true', parameters('domainName'), parameters('domainNetbiosName'))]",
      "$dsrmPasswordPlain = $null",
      "shutdown.exe /r /t 60 /c 'Restart after Active Directory Domain Services installation'",
      "exit 0"
    ],
    "installAdCommand": "[format('powershell.exe -ExecutionPolicy Unrestricted -NoProfile -Command \"{0}\"', join(variables('installAdScriptLines'), '; '))]",
    "location": "[resourceGroup().location]",
    "vnetAddressPrefix": "10.69.0.0/16",
    "subnetPrefix": "10.69.0.0/24",
    "vmPrivateIpAddress": "10.69.0.4"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('nsgName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "[variables('rdpRuleName')]",
            "properties": {
              "priority": 1000,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "[format('{0}/32', parameters('sourceIpAddress'))]",
              "destinationAddressPrefix": "*",
              "description": "Allow RDP only from the configured administrator IP address."
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[variables('vnetAddressPrefix')]"
          ]
        },
        "dhcpOptions": {
          "dnsServers": [
            "[variables('vmPrivateIpAddress')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "[variables('subnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[variables('publicIpName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[variables('nicName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('vmPrivateIpAddress')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmName')]",
      "location": "[variables('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-datacenter-azure-edition",
            "version": "latest"
          },
          "osDisk": {
            "name": "[variables('osDiskName')]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]",
              "properties": {
                "primary": true
              }
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', variables('vmName'), 'install-ad-ds')]",
      "location": "[variables('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "protectedSettings": {
          "commandToExecute": "[variables('installAdCommand')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "virtualMachineName": {
      "type": "string",
      "value": "[variables('vmName')]"
    },
    "privateIPAddress": {
      "type": "string",
      "value": "[variables('vmPrivateIpAddress')]"
    },
    "publicIPAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName')), '2023-11-01').ipAddress]"
    },
    "rdpCommand": {
      "type": "string",
      "value": "[format('mstsc /v:{0}', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName')), '2023-11-01').ipAddress)]"
    },
    "activeDirectoryDomain": {
      "type": "string",
      "value": "[parameters('domainName')]"
    },
    "postDeploymentNote": {
      "type": "string",
      "value": "The VM restarts after the AD DS installation. Wait several minutes before testing the new domain controller."
    }
  }
}
