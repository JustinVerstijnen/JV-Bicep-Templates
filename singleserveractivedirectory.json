{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "10241162623851324796"
    }
  },
  "parameters": {
    "projectName": {
      "type": "string",
      "defaultValue": "biceptst",
      "minLength": 2,
      "maxLength": 8,
      "metadata": {
        "description": "Short project name. Keep this short because the Windows computer name has a 15 character limit."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region where the resources will be deployed. By default, the resource group location is used."
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "justin-admin",
      "metadata": {
        "description": "Local administrator username for the Windows Server VM."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Local administrator password for the Windows Server VM and the Active Directory DSRM password. Use a strong password."
      }
    },
    "sourceIpAddress": {
      "type": "string",
      "metadata": {
        "description": "Public IPv4 address that is allowed to connect with RDP. Enter only the IP address, without /32."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_D2as_v7",
      "metadata": {
        "description": "Windows Server VM size."
      }
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.69.0.0/16",
      "metadata": {
        "description": "Virtual network address space."
      }
    },
    "subnetPrefix": {
      "type": "string",
      "defaultValue": "10.69.0.0/24",
      "metadata": {
        "description": "Subnet address space."
      }
    },
    "vmPrivateIpAddress": {
      "type": "string",
      "defaultValue": "10.69.0.4",
      "metadata": {
        "description": "Static private IP address for the domain controller."
      }
    },
    "domainName": {
      "type": "string",
      "defaultValue": "justinverstijnen.nl",
      "metadata": {
        "description": "Active Directory domain name to create on the server."
      }
    },
    "domainNetbiosName": {
      "type": "string",
      "defaultValue": "JV",
      "minLength": 1,
      "maxLength": 15,
      "metadata": {
        "description": "Active Directory NetBIOS name to create on the server."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "deployment": "bicep",
        "workload": "single-server-ad-lab"
      },
      "metadata": {
        "description": "Tags applied to all supported resources."
      }
    }
  },
  "variables": {
    "lowerProjectName": "[toLower(parameters('projectName'))]",
    "namePrefix": "[format('jv-{0}', variables('lowerProjectName'))]",
    "vnetName": "[format('vnet-{0}', variables('namePrefix'))]",
    "subnetName": "[format('snet-{0}', variables('namePrefix'))]",
    "nsgName": "[format('nsg-{0}', variables('namePrefix'))]",
    "publicIpName": "[format('pip-{0}', variables('namePrefix'))]",
    "nicName": "[format('nic-{0}', variables('namePrefix'))]",
    "vmName": "[format('vm-{0}', variables('namePrefix'))]",
    "osDiskName": "[format('osdisk-{0}', variables('namePrefix'))]",
    "rdpRuleName": "allow-rdp-from-admin-ip",
    "encodedAdminPassword": "[base64(parameters('adminPassword'))]",
    "installAdScriptLines": [
      "$ErrorActionPreference = 'Stop'",
      "Install-WindowsFeature AD-Domain-Services -IncludeManagementTools",
      "[format('$adminPasswordPlain = [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String(''{0}''))', variables('encodedAdminPassword'))]",
      "$securePassword = ConvertTo-SecureString $adminPasswordPlain -AsPlainText -Force",
      "[format('Install-ADDSForest -DomainName ''{0}'' -DomainNetbiosName ''{1}'' -SafeModeAdministratorPassword $securePassword -InstallDNS -Force -NoRebootOnCompletion:$true', parameters('domainName'), parameters('domainNetbiosName'))]",
      "$adminPasswordPlain = $null",
      "shutdown.exe /r /t 60 /c 'Restart after Active Directory Domain Services installation'",
      "exit 0"
    ],
    "installAdCommand": "[format('powershell.exe -ExecutionPolicy Unrestricted -NoProfile -Command \"{0}\"', join(variables('installAdScriptLines'), '; '))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('nsgName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "[variables('rdpRuleName')]",
            "properties": {
              "priority": 1000,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "[format('{0}/32', parameters('sourceIpAddress'))]",
              "destinationAddressPrefix": "*",
              "description": "Allow RDP only from the configured administrator IP address."
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressPrefix')]"
          ]
        },
        "dhcpOptions": {
          "dnsServers": [
            "[parameters('vmPrivateIpAddress')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "[parameters('subnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[variables('publicIpName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[variables('nicName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[parameters('vmPrivateIpAddress')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-datacenter-azure-edition",
            "version": "latest"
          },
          "osDisk": {
            "name": "[variables('osDiskName')]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]",
              "properties": {
                "primary": true
              }
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', variables('vmName'), 'install-ad-ds')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "protectedSettings": {
          "commandToExecute": "[variables('installAdCommand')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "virtualMachineName": {
      "type": "string",
      "value": "[variables('vmName')]"
    },
    "privateIPAddress": {
      "type": "string",
      "value": "[parameters('vmPrivateIpAddress')]"
    },
    "publicIPAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName')), '2023-11-01').ipAddress]"
    },
    "rdpCommand": {
      "type": "string",
      "value": "[format('mstsc /v:{0}', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName')), '2023-11-01').ipAddress)]"
    },
    "activeDirectoryDomain": {
      "type": "string",
      "value": "[parameters('domainName')]"
    },
    "postDeploymentNote": {
      "type": "string",
      "value": "The VM restarts after the AD DS installation. Wait several minutes before testing the new domain controller."
    }
  }
}
